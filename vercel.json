{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    {
      "source": "/coach-report/:path*",
      "destination": "/coach-report/:path*"
    },
    {
      "source": "/coach-report-wk12/:path*",
      "destination": "/coach-report-wk12/:path*"
    },
    {
      "source": "/grocery/shopping-list",
      "destination": "/grocery/index.html"
    },
    {
      "source": "/grocery/shopping",
      "destination": "/grocery/index.html"
    },
    {
      "source": "/grocery/:path*",
      "destination": "/grocery/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

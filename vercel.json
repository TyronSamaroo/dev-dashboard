{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    {
      "source": "/prep-runway/:path*",
      "destination": "/prep-runway/:path*"
    },
    {
      "source": "/coach-report/:path*",
      "destination": "/coach-report/:path*"
    },
    {
      "source": "/coach-report-wk12/:path*",
      "destination": "/coach-report-wk12/:path*"
    },
    {
      "source": "/grocery/:path*",
      "destination": "/grocery/:path*"
    },
    {
      "source": "/coding-review/:path*",
      "destination": "/coding-review/:path*"
    },
    {
      "source": "/love/:path*",
      "destination": "/love/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
